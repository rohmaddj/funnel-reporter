# =============================================================================
# Ask Sabrina — Funnel Reporter
# Copy this file to .env and fill in your values
# Never commit .env to git — add it to .gitignore
# =============================================================================

# ── ClickBank ─────────────────────────────────────────────────────────────────
# How to get:
#   1. Log in to ClickBank → Accounts → select SABRINAPSY
#   2. Account Settings → Edit → Developer API Keys
#   3. "Clerk API Key" = CLICKBANK_APP_KEY
#   4. Developer API key = CLICKBANK_DEV_KEY
#      (your profile top-right → Edit Account Info → API Key section)
#   Docs: https://api.clickbank.com

CLICKBANK_API_KEY=
CLICKBANK_ACCOUNT=SABRINAPSY

# ── CPV Labs ──────────────────────────────────────────────────────────────────
# How to get:
#   1. Log in to CPV Lab → top-right avatar → API Access (or Settings → API)
#   2. Copy the API key shown there
#   3. Base URL: check the browser address bar — usually https://app.cpvlab.com
#      but some accounts use a custom subdomain
#   Docs: Settings → API Documentation inside your CPV account

CPVLABS_API_KEY=
CPVLABS_BASE_URL=https://app.cpvlab.com/api/v1

# ── Facebook / Instagram ──────────────────────────────────────────────────────
# OPTION A — Quick token (expires ~60 days, good for testing):
#   1. https://developers.facebook.com/tools/explorer
#   2. Select your App → Generate Access Token
#   3. Add permissions: ads_read, ads_management, read_insights
#   4. Copy token → FB_ACCESS_TOKEN
#
# OPTION B — System User token (never expires, use for production):
#   1. business.facebook.com → Settings → Users → System Users → Add
#   2. Give Analyst role on your ad account
#   3. Generate token → select app → add: ads_read, ads_management, read_insights
#
# FB_AD_ACCOUNT_ID: business.facebook.com → Ad Accounts
#   ID is in the URL. Include the "act_" prefix e.g. act_123456789
#
# Docs: https://developers.facebook.com/docs/marketing-api

FB_ACCESS_TOKEN=
FB_AD_ACCOUNT_ID=act_
FB_SGD_TO_USD_RATE=0.743

# ── Maropost ──────────────────────────────────────────────────────────────────
# USE_CPV_FOR_EMAIL=true means Maropost is skipped — email attribution
# comes from CPV Labs postbacks instead. Only flip to false if you want
# Maropost send/open/click stats on top of CPV conversion data.
#
# How to get (only needed if USE_CPV_FOR_EMAIL=false):
#   1. Maropost → Settings → API Keys → create or copy key
#   2. Account ID is in the URL: app.maropost.com/accounts/XXXXX
#   Docs: https://developers.maropost.com/documentation

MAROPOST_API_KEY=
MAROPOST_ACCOUNT_ID=
USE_CPV_FOR_EMAIL=true

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# How to get:
#   1. https://console.anthropic.com → Settings → API Keys → Create Key
#   Docs: https://docs.anthropic.com

ANTHROPIC_API_KEY=

# ── Google (Sheets + Docs + Gmail) ───────────────────────────────────────────
# How to get:
#   1. https://console.cloud.google.com → create project (e.g. "funnel-reporter")
#   2. Enable all three APIs:
#        Google Sheets API
#        Google Docs API
#        Gmail API
#   3. IAM & Admin → Service Accounts → Create Service Account
#      Name: funnel-reporter → skip role → Done
#   4. Click the service account → Keys → Add Key → JSON → Download
#      Save the file as google_credentials.json in this project folder
#   5. Copy the service account email (name@project.iam.gserviceaccount.com)
#
#   Share your Google Sheet with that service account email as Editor:
#     Open sheet → Share → paste the email → Editor → Send
#
#   Gmail sending note:
#     Service accounts can't send Gmail directly unless you have Google Workspace
#     with domain-wide delegation enabled. For personal Gmail, use SendGrid instead
#     (see SENDGRID_API_KEY below — easier and free for this volume).

GOOGLE_CREDENTIALS_FILE=google_credentials.json

# ── Report delivery ───────────────────────────────────────────────────────────
REPORT_EMAIL_TO=                      # recipient(s), comma-separated
REPORT_EMAIL_FROM=                    # verified sender address

# ── SendGrid (recommended over Gmail API for personal Gmail accounts) ─────────
# Easier setup, free tier = 100 emails/day
# How to get:
#   1. https://sendgrid.com → sign up free
#   2. Settings → API Keys → Create API Key → Full Access → copy key
#   3. Settings → Sender Authentication → Single Sender Verification
#      Verify the same address as REPORT_EMAIL_FROM
#
# If SENDGRID_API_KEY is set, report.py uses SendGrid instead of Gmail API

SENDGRID_API_KEY=

# ── GitHub Actions ────────────────────────────────────────────────────────────
# Add every variable above as a Repository Secret:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# Special case for google_credentials.json:
#   Secret name: GOOGLE_CREDENTIALS_JSON
#   Secret value: paste the entire contents of the JSON file
#   The workflow writes it to a file at runtime (see .github/workflows/weekly_report.yml)
