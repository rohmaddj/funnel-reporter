# =============================================================================
# Funnel Reporter — Multi-Project
# Copy this file to .env and fill in your values
# Never commit .env to git — it is in .gitignore
# =============================================================================
# Projects:
#   asksabrina       → asksabrina.com
#   astroloversketch → astroloversketch.com
# =============================================================================


# ── Project to run ────────────────────────────────────────────────────────────
# Used by collect.py / analyse.py / report.py via --project flag.
# Set here as the default so plain `python collect.py` works locally.

PROJECT=asksabrina


# =============================================================================
# ASK SABRINA
# =============================================================================

# ── ClickBank ─────────────────────────────────────────────────────────────────
# 1. Log in to ClickBank → Accounts → select SABRINAPSY
# 2. Account Settings → Edit → Developer API Keys → Clerk API Key
# Docs: https://api.clickbank.com

ASKSABRINA_CLICKBANK_API_KEY=
ASKSABRINA_CLICKBANK_VENDOR=SABRINAPSY

# ── CPV Labs ──────────────────────────────────────────────────────────────────
# Same instance for all projects — only group name differs

ASKSABRINA_CPVLABS_API_KEY=
ASKSABRINA_CPVLABS_BASE_URL=https://cpvlab.asksabrina.com
ASKSABRINA_CPVLABS_GROUP=Ask Sabrina

# ── Facebook ──────────────────────────────────────────────────────────────────
# System User token (never expires) recommended for production.
# business.facebook.com → Settings → Users → System Users
# FB_AD_ACCOUNT_ID: include act_ prefix e.g. act_123456789

ASKSABRINA_FB_ACCESS_TOKEN=
ASKSABRINA_FB_AD_ACCOUNT_ID=act_
ASKSABRINA_FB_SGD_TO_USD_RATE=0.743

# ── Maropost ──────────────────────────────────────────────────────────────────
# USE_CPV_FOR_EMAIL=true skips Maropost — email attribution comes from CPV Labs

ASKSABRINA_MAROPOST_API_KEY=
ASKSABRINA_MAROPOST_ACCOUNT_ID=
ASKSABRINA_USE_CPV_FOR_EMAIL=true

# ── Google / GA4 ──────────────────────────────────────────────────────────────
# GA4 Property ID: GA4 → Admin → Property Settings → Property ID (number only)
# Google Sheet ID: the long ID from the sheet URL

ASKSABRINA_GA4_PROPERTY_ID=
ASKSABRINA_SHEET_ID=
ASKSABRINA_SHEET_TAB=Weekly Data

# ── Report delivery ───────────────────────────────────────────────────────────

ASKSABRINA_REPORT_EMAIL_TO=
ASKSABRINA_REPORT_EMAIL_FROM=
ASKSABRINA_REPORT_EMAIL_NAME=Funnel Reports

# ── Config file ───────────────────────────────────────────────────────────────

ASKSABRINA_CONFIG_FILE=config/asksabrina.yaml


# =============================================================================
# ASTRO LOVER SKETCH
# =============================================================================

# ── ClickBank ─────────────────────────────────────────────────────────────────

ASTRO_CLICKBANK_API_KEY=
ASTRO_CLICKBANK_VENDOR=ASTROSKETC

# ── CPV Labs ──────────────────────────────────────────────────────────────────

ASTRO_CPVLABS_API_KEY=
ASTRO_CPVLABS_BASE_URL=https://cpvlab.asksabrina.com
ASTRO_CPVLABS_GROUP=Astro Lover Sketch

# ── Facebook ──────────────────────────────────────────────────────────────────

ASTRO_FB_ACCESS_TOKEN=
ASTRO_FB_AD_ACCOUNT_ID=act_
ASTRO_FB_SGD_TO_USD_RATE=0.743

# ── Maropost ──────────────────────────────────────────────────────────────────

ASTRO_MAROPOST_API_KEY=
ASTRO_MAROPOST_ACCOUNT_ID=
ASTRO_USE_CPV_FOR_EMAIL=true

# ── Google / GA4 ──────────────────────────────────────────────────────────────

ASTRO_GA4_PROPERTY_ID=
ASTRO_SHEET_ID=
ASTRO_SHEET_TAB=Weekly Data

# ── Report delivery ───────────────────────────────────────────────────────────

ASTRO_REPORT_EMAIL_TO=
ASTRO_REPORT_EMAIL_FROM=
ASTRO_REPORT_EMAIL_NAME=Funnel Reports

# ── Config file ───────────────────────────────────────────────────────────────

ASTRO_CONFIG_FILE=config/astroloversketch.yaml


# =============================================================================
# SHARED — same across all projects
# =============================================================================

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# https://console.anthropic.com → Settings → API Keys → Create Key

ANTHROPIC_API_KEY=

# ── Google credentials (shared service account) ───────────────────────────────
# 1. https://console.cloud.google.com → IAM → Service Accounts → Create
# 2. Keys → Add Key → JSON → save as google_credentials.json
# 3. Share each Google Sheet with the service account email as Editor
# 4. Add service account email as Viewer in each GA4 property
# 5. For GitHub Actions: add full JSON content as secret GOOGLE_CREDENTIALS_JSON

GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# ── SendGrid ──────────────────────────────────────────────────────────────────
# https://sendgrid.com → Settings → API Keys → Create API Key → Full Access
# Verify sender in Settings → Sender Authentication → Single Sender Verification

SENDGRID_API_KEY=

# ── GitHub Actions ────────────────────────────────────────────────────────────
# Add every variable above as a Repository Secret:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# Special case for google_credentials.json:
#   Secret name: GOOGLE_CREDENTIALS_JSON
#   Secret value: paste entire contents of google_credentials.json
